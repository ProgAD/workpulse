# copy to config/.env and fill for your machine
# DB_SOCKET: xampp mac uses unix socket. leave empty on windows/linux to use DB_HOST
DB_SOCKET=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock
DB_HOST=127.0.0.1
DB_NAME=hrms
DB_USER=root
DB_PASS=

# hostinger pe deploy karte waqt aisa hoga (values apni daalo):
# DB_SOCKET=
# DB_HOST=localhost        <- server pe chal raha ho to localhost, remote se srv1130.hstgr.io
# DB_PORT=3306
# DB_NAME=u214833083_hrms
