# copy karke config/.env banao aur apni machine ki values bharo
# app local xampp/mysql pe chalta hai

# mac xampp - socket use karo (ye default hai):
DB_SOCKET=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hrms
DB_USER=root
DB_PASS=

# windows/linux xampp - DB_SOCKET khali chhod do, host/port se connect hoga:
# DB_SOCKET=
# DB_HOST=127.0.0.1
